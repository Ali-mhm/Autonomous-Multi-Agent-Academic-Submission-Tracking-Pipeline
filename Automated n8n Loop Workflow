    {
      "parameters": {
        "jsCode": "const body = ($json.textAsHtml || $json.text || $json.html || '').toLowerCase();\nconst subject = ($json.subject || '').toLowerCase();\nlet status = 'PENDING';\n\nif (body.includes('revise') || body.includes('revision') || body.includes('major changes') || body.includes('minor changes') || body.includes('request modifications')) {\n  status = 'REVISED';\n} else if (body.includes('reject') || body.includes('decline') || body.includes('unsuitable') || body.includes('not pass') || body.includes('regret to inform')) {\n  status = 'REJECTED';\n} else if (body.includes('accept') || body.includes('publish') || body.includes('approved')) {\n  status = 'ACCEPTED';\n} else if (body.includes('submitted') || body.includes('received') || body.includes('successful submission') || body.includes('under review')) {\n  status = 'PENDING';\n}\n\nreturn {\n  status,\n  subject,\n  email_date: $json.date || new Date().toISOString()\n};"
      },
      "id": "parse_decision_node",
      "name": "Parse Decision Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        300,
        300
      ]
    },
    {
      "parameters": {
        "documentId": {
          "__rl": true,
          "value": "1vWMGK_597Wuf6gh0tszrh97-l0YfVCWoMGXmQqT5CWw",
          "mode": "id"
        },
        "sheetName": "Curated Shortlist",
        "filters": {
          "conditions": [
            {
              "key": "Journal Name",
              "operator": "regex",
              "value": "={{ $json.subject }}"
            }
          ]
        },
        "columns": {
