def shortlist_journals(client, df_metrics, abstract):
    """Filter and rank journals based on criteria."""
    raw_journals_data = df_metrics.to_dict(orient="records")
    
    print(f"🧠 Editorial Agent: Screening journals against your specific criteria...")
    print("🎯 Filters: Impact Factor between 2 and 10 | Quartile must be Q1 or Q2 | High Scope Match")
    
    prompt = f"""
    You are an expert senior academic editor ranking journals for a research paper submission.
    
    Your Task:
    Review the list of candidate journals provided below and evaluate them against 
    the author's target abstract and target constraints.
    
    Author's Target Abstract:
    {abstract}
    
    Target Constraints:
    - Impact Factor: Must be between 2.0 and 10.0.
    - Quartile: Must be Q1 or Q2.
    
    Candidate Journals Data:
    {json.dumps(raw_journals_data, indent=2)}
    
    Evaluation Rules:
    1. Filter out any journal that clearly violates the target constraints 
       (e.g., Impact Factor under 2 or over 10, or Q3/Q4 quartile).
    2. For journals that pass the filter, evaluate how well the journal's typical 
       scientific scope aligns with the technical themes in the abstract 
       (multi-omics, DNA methylation, bioinformatics networks, colon cancer/oncology).
    3. Assign a "Scope Match %" (0% to 100%) and write a brief 1-sentence 
       "Editorial Reason" explaining why it's a good match.
    
    Output your entire response strictly as a valid JSON list of objects. 
    Do not include markdown formatting. Use this exact structure:
    [
        {{
            "Journal Name": "Example Journal",
            "Impact Factor": 4.5,
            "Quartile": "Q1",
            "Publisher": "Example Publisher",
            "Scope Match %": 95,
            "Editorial Reason": "Strong fit because they frequently publish..."
        }}
    ]
    """
    
    try:
        response = client.models.generate_content(
            model='models/gemini-flash-latest',
            contents=prompt
        )
        
        clean_json_str = response.text.replace("```json", "").replace("```", "").strip()
        shortlisted_data = json.loads(clean_json_str)
        
        df_shortlist = pd.DataFrame(shortlisted_data)
        df_shortlist = df_shortlist.sort_values(by="Scope Match %", ascending=False)
        
        print(f"\n🎉 Shortlist ready! Found {len(df_shortlist)} journals that perfectly fit your preferences.")
        return df_shortlist
        
    except Exception as e:
        print(f"❌ Error during screening: {e}")
        return pd.DataFrame()

