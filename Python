    top_journal = df_shortlist.iloc[0]
    target_journal_name = top_journal["Journal Name"]
    
    print(f"✍️ Drafting cover letter for your #1 ranked journal: '{target_journal_name}'...\n")
    
    prompt = f"""
    You are a professional academic writing assistant. Write a formal, persuasive 
    Cover Letter to the Editor-in-Chief for a research manuscript submission.
    
    Target Journal: {target_journal_name}
    
    Manuscript Abstract:
    {abstract}
    
    Requirements:
    1. Use a professional, standard academic cover letter layout 
       (with bracketed placeholders for the date, author name, and affiliation).
    2. Clearly state the title of the manuscript 
       (use a placeholder title like "[Insert Your Manuscript Title Here]").
    3. Explicitly explain why this work aligns with the specific scope of 
       {target_journal_name}. Mention keywords like multi-omics, DNA methylation, 
       and network biology.
    4. Explicitly state that the manuscript is original, has not been published 
       elsewhere, and all authors have approved the submission.
    5. Maintain an elegant, confident, and respectful scholarly tone. 
       Keep it concise (under 400 words).
    """
    
    response = client.models.generate_content(
        model='models/gemini-flash-latest',
        contents=prompt
    )
    
    cover_letter_text = response.text.strip()
    
    print("=" * 70)
    print(f"📄 GENERATED COVER LETTER FOR: {target_journal_name}")
    print("=" * 70)
    print(cover_letter_text)
    print("=" * 70)
    
    filename = "generated_cover_letter.txt"
    with open(filename, "w") as f:
        f.write(cover_letter_text)
    print(f"\n💾 Saved to Colab workspace as '{filename}'.")
    
    return cover_letter_text

