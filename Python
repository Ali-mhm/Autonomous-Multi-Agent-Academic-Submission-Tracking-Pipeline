def create_curated_shortlist_tab(df_shortlist, spreadsheet_name, tab_name="Curated Shortlist"):
    """Create a new tab in Google Sheets for the curated shortlist."""
    gc = connect_to_google_sheets()
    sh = gc.open(spreadsheet_name)
    
    try:
        worksheet = sh.worksheet(tab_name)
        print(f"📊 Found existing tab: '{tab_name}'. Clearing old data to update...")
        worksheet.clear()
    except gspread.exceptions.WorksheetNotFound:
        print(f"✨ Creating a brand-new tab named '{tab_name}' inside your spreadsheet...")
        worksheet = sh.add_worksheet(title=tab_name, rows="100", cols="10")
    
    headers = list(df_shortlist.columns)
    worksheet.append_row(headers)
    print("📋 Shortlist headers successfully written to Row 1!")
    
    print(f"⏳ Writing your custom ranked targets into '{tab_name}'...")
    df_clean_shortlist = df_shortlist.fillna("N/A")
    rows_to_append = df_clean_shortlist.values.tolist()
    worksheet.append_rows(rows_to_append)
    
    print(f"\n🎉 SUCCESS! Your elite shortlist of {len(rows_to_append)} journals is saved!")
    print(f"👉 Open your Google Sheet browser tab to see your new 'Curated Shortlist' tab update live!")

