def extract_keywords(client, abstract):
    """Extract core technical keyphrases from the abstract."""
    prompt = f"""
    Read the following research abstract and extract the 4 to 6 most important 
    core technical keyphrases. Wrap each keyphrase in double quotes, and separate 
    them with spaces so a database can search them perfectly. Do not include any 
    introductory text, bullet points, or extra explanation. Only return the 
    quoted phrases.

    Abstract:
    {abstract}
    """
    
    response = client.models.generate_content(
        model='models/gemini-flash-latest',
        contents=prompt,
    )
    return response.text.strip()

