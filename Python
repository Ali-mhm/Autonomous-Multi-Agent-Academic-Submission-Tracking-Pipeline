def enrich_journals_with_metrics(client, journal_list):
    """Enrich journal data with Impact Factor and Quartile information."""
    journal_names = [item["Journal Name"] for item in journal_list]
    
    prompt = f"""
    You are an academic database metrics engine. Look up or accurately estimate 
    the current real Impact Factor and the standard SCImago Journal Quartile 
    (Q1, Q2, Q3, or Q4) for the scientific journals listed below.
    
    Journal List:
    {journal_names}
    
    Output your entire response strictly as a valid JSON list of objects. 
    Do not include markdown formatting like ```json or any conversational text. 
    Use this exact structure:
    [
        {{"journal_name": "Exact Journal Name", "impact_factor": 4.5, "quartile": "Q1"}}
    ]
    """
    
    try:
        response = client.models.generate_content(
            model='models/gemini-flash-latest',
            contents=prompt
        )
        
        clean_json_str = response.text.replace("```json", "").replace("```", "").strip()
        ai_metrics_list = json.loads(clean_json_str)
        
        metrics_map = {item["journal_name"].lower().strip(): item for item in ai_metrics_list}
        
        enriched_journals = []
        for entry in journal_list:
            original_name = entry["Journal Name"]
            lookup_key = original_name.lower().strip()
            
            ai_data = metrics_map.get(lookup_key, {})
            impact = ai_data.get("impact_factor", "N/A")
            quartile = ai_data.get("quartile", "N/A")
            
            enriched_journals.append({
                "Journal Name": original_name,
                "Impact Factor": impact,
                "Quartile": quartile,
                "Publisher": entry["Publisher"],
                "Matched Title From Database": entry["Matched Article Title"]
            })
        
        df_final_metrics = pd.DataFrame(enriched_journals)
        df_final_metrics = df_final_metrics.sort_values(
            by="Impact Factor", 
            ascending=False, 
            key=lambda x: pd.to_numeric(x, errors='coerce').fillna(-1)
        )
        
        print("🎯 Success! Metric columns are populated.")
        return df_final_metrics
        
    except Exception as e:
        print(f"❌ Error during structured processing: {e}")
        return pd.DataFrame(journal_list)

