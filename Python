def connect_to_google_sheets():
    """Authenticate and connect to Google Sheets."""
    print("🔐 Authenticating your Google Drive and Sheets access...")
    auth.authenticate_user()
    creds, _ = default()
    gc = gspread.authorize(creds)
    return gc

def create_or_open_spreadsheet(gc, spreadsheet_name):
    """Create a new spreadsheet or open existing one."""
    try:
        sh = gc.open(spreadsheet_name)
        worksheet = sh.get_worksheet(0)
        print(f"📊 Connected to existing sheet: '{spreadsheet_name}'")
        return sh, worksheet
    except gspread.exceptions.SpreadsheetNotFound:
        print(f"✨ Creating a brand-new Google Sheet named '{spreadsheet_name}'...")
        sh = gc.create(spreadsheet_name)
        worksheet = sh.get_worksheet(0)
        
        headers = ["Journal Name", "Impact Factor", "Quartile", "Publisher", "Matched Database Article Title"]
        worksheet.append_row(headers)
        print("📋 Header layout successfully written to Row 1!")
        return sh, worksheet

def write_to_google_sheets(df, spreadsheet_name):
    """Write DataFrame to Google Sheets."""
    gc = connect_to_google_sheets()
    sh, worksheet = create_or_open_spreadsheet(gc, spreadsheet_name)
    
    print("⏳ Writing your journals into the spreadsheet layout...")
    df_clean = df.fillna("N/A")
    rows_to_append = df_clean.values.tolist()
    worksheet.append_rows(rows_to_append)
    
    print(f"\n🎉 ALL DONE! Added {len(rows_to_append)} rows to your spreadsheet!")
    return sh

